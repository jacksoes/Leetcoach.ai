{
  "manifest_version": 3,
  "name": "LeetCode Overlay",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["./dist/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/assets/*", "dist/*"],
      "matches": ["<all_urls>"]
    }
  ]
}